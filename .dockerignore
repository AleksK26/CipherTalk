# flyctl launch added from vendor\github.com\gofrs\uuid\.gitignore
# Binaries for programs and plugins
vendor\github.com\gofrs\uuid\**\*.exe
vendor\github.com\gofrs\uuid\**\*.exe~
vendor\github.com\gofrs\uuid\**\*.dll
vendor\github.com\gofrs\uuid\**\*.so
vendor\github.com\gofrs\uuid\**\*.dylib

# Test binary, build with `go test -c`
vendor\github.com\gofrs\uuid\**\*.test

# Output of the go coverage tool, specifically when used with LiteIDE
vendor\github.com\gofrs\uuid\**\*.out

# binary bundle generated by go-fuzz
vendor\github.com\gofrs\uuid\**\uuid-fuzz.zip

# flyctl launch added from vendor\github.com\gorilla\handlers\.gitignore
# Output of the go test coverage tool
vendor\github.com\gorilla\handlers\**\coverage.coverprofile

